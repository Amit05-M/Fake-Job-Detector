{
  "manifest_version": 3,
  "name": "Fake Job Detector India",
  "version": "1.0",
  "description": "Detects fake job posts on Naukri, LinkedIn, Indeed using ML",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "https://*.naukri.com/*",
    "https://*.linkedin.com/*",
    "https://*.indeed.com/*",
    "https://*.shine.com/*",
    "https://*.monster.com/*",
    "https://*.foundit.in/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Fake Job Detector",
    "default_icon": {
      "16":  "icon16.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16":  "icon16.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.naukri.com/*",
        "https://*.linkedin.com/*",
        "https://*.indeed.com/*",
        "https://*.shine.com/*",
        "https://*.foundit.in/*"
      ],
      "js": ["content.js"]
    }
  ]
}